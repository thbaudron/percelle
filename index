<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
<title>Adopte un RIEN.</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Montserrat:ital,wght@0,400;0,600;0,700;1,400&display=swap" rel="stylesheet">
<style>
  /* ============================================================
     CHARTE GRAPHIQUE — SURFRIDER FOUNDATION EUROPE
     Bleu Surfrider #0073BE · Bleu sombre #1A3047 · Blanc · Amande #ECE4CD
     Typo : Bebas Neue (titres H1) / Montserrat (tout le reste)
     ============================================================ */
  :root{
    --bleu-surfrider:#0073BE;
    --bleu-sombre:#1A3047;
    --bleu-clair:#cbdff5;
    --blanc:#FFFFFF;
    --amande:#ECE4CD;
    --noir:#0a131d;
  }
  *{margin:0;padding:0;box-sizing:border-box;-webkit-tap-highlight-color:transparent;}
  html,body{height:100%;}
  body{
    font-family:'Montserrat',sans-serif;
    background:var(--noir);
    color:var(--blanc);
    overflow:hidden;
    position:fixed;width:100%;
  }
  h1{font-family:'Bebas Neue',sans-serif;text-transform:uppercase;font-weight:400;line-height:.92;letter-spacing:.01em;}
  .h2{font-family:'Montserrat',sans-serif;font-weight:700;text-transform:uppercase;color:var(--bleu-surfrider);letter-spacing:.06em;}
  /* tiret de titrage (charte p.17) — ratio 5:1, fonctionne avec le H1 */
  .dash{width:54px;height:11px;background:var(--bleu-surfrider);margin:18px 0 26px;border-radius:1px;}
  .dash.center{margin-left:auto;margin-right:auto;}

  /* --------- Boutons (charte p.17) : Montserrat majuscule --------- */
  .btn{
    font-family:'Montserrat',sans-serif;font-weight:700;text-transform:uppercase;
    letter-spacing:.08em;font-size:14px;border:none;cursor:pointer;
    padding:17px 34px;border-radius:2px;transition:.25s ease;
  }
  .btn-plein{background:var(--bleu-surfrider);color:var(--blanc);}
  .btn-plein:hover{background:#0086da;transform:translateY(-2px);box-shadow:0 10px 30px rgba(0,115,190,.35);}
  .btn-contour{background:transparent;color:var(--blanc);border:1.5px solid rgba(255,255,255,.45);}
  .btn-contour:hover{border-color:var(--bleu-surfrider);color:var(--bleu-clair);}
  .btn[disabled]{opacity:.4;cursor:default;transform:none;box-shadow:none;}

  /* --------- Screens --------- */
  .screen{
    position:absolute;inset:0;display:flex;flex-direction:column;
    align-items:center;justify-content:center;text-align:center;
    padding:36px 26px;opacity:0;pointer-events:none;
    transition:opacity .8s ease;z-index:1;
  }
  .screen.active{opacity:1;pointer-events:auto;z-index:2;}
  .wrap{width:100%;max-width:560px;margin:0 auto;}

  /* --------- Intro --------- */
  #s-intro{background:radial-gradient(circle at 50% 60%, #122234 0%, var(--noir) 70%);}
  .lueur{
    width:14px;height:14px;border-radius:50%;background:var(--bleu-surfrider);
    margin:0 auto 40px;box-shadow:0 0 24px 6px rgba(0,115,190,.7);
    animation:pulse 2.6s ease-in-out infinite;
  }
  @keyframes pulse{0%,100%{transform:scale(1);opacity:.55;}50%{transform:scale(1.55);opacity:1;}}
  #s-intro h1{font-size:clamp(64px,18vw,120px);}
  .sub{font-size:15px;line-height:1.65;color:rgba(255,255,255,.7);margin-top:8px;font-weight:400;}
  .tap{margin-top:46px;font-size:12px;letter-spacing:.22em;text-transform:uppercase;color:rgba(255,255,255,.45);animation:blink 2.4s infinite;font-weight:600;}
  @keyframes blink{0%,100%{opacity:.35;}50%{opacity:.85;}}

  /* --------- Principe --------- */
  #s-principe h1{font-size:clamp(40px,9vw,62px);}
  .lead{font-size:16px;line-height:1.7;color:rgba(255,255,255,.82);font-weight:400;margin-bottom:14px;}
  .lead b{color:var(--bleu-clair);font-weight:700;}

  /* --------- Carte --------- */
  #s-carte{padding:0;justify-content:flex-start;}
  #ocean{position:absolute;inset:0;width:100%;height:100%;display:block;}
  .carte-top{
    position:absolute;top:0;left:0;right:0;z-index:5;padding:22px 24px 40px;
    background:linear-gradient(to bottom, rgba(10,19,29,.92) 0%, rgba(10,19,29,.55) 60%, transparent 100%);
    text-align:left;pointer-events:none;
  }
  .carte-top .h2{font-size:13px;}
  .carte-top h1{font-size:clamp(30px,7vw,44px);margin-top:4px;}
  .meta{display:flex;gap:26px;margin-top:14px;}
  .meta .num{font-family:'Bebas Neue',sans-serif;font-size:34px;line-height:1;color:var(--bleu-surfrider);}
  .meta .lbl{font-size:10px;letter-spacing:.12em;text-transform:uppercase;color:rgba(255,255,255,.55);margin-top:3px;font-weight:600;}
  .barre{margin-top:14px;height:5px;width:100%;max-width:300px;background:rgba(255,255,255,.12);border-radius:3px;overflow:hidden;}
  .barre i{display:block;height:100%;width:2%;background:var(--bleu-surfrider);transition:width 1s ease;border-radius:3px;}
  .hint{position:absolute;bottom:118px;left:0;right:0;text-align:center;z-index:5;font-size:12px;letter-spacing:.05em;color:rgba(255,255,255,.7);pointer-events:none;text-shadow:0 2px 8px rgba(0,0,0,.6);font-weight:600;transition:opacity .4s;}
  .carte-bottom{position:absolute;bottom:0;left:0;right:0;z-index:6;padding:18px 24px calc(20px + env(safe-area-inset-bottom));background:linear-gradient(to top, rgba(10,19,29,.95), transparent);display:flex;justify-content:center;}
  .parcel-info{position:absolute;bottom:96px;left:0;right:0;z-index:6;text-align:center;opacity:0;transition:.4s;pointer-events:none;}
  .parcel-info.show{opacity:1;}
  .parcel-info .pid{font-family:'Bebas Neue',sans-serif;font-size:30px;color:var(--blanc);letter-spacing:.04em;}
  .parcel-info .coord{font-size:13px;color:var(--bleu-clair);font-weight:600;margin-top:2px;}

  /* --------- Formulaire email --------- */
  #s-email h1{font-size:clamp(34px,8vw,52px);}
  .field{margin:30px auto 8px;max-width:380px;width:100%;}
  .field input{
    width:100%;background:transparent;border:none;border-bottom:1.5px solid rgba(255,255,255,.35);
    color:var(--blanc);font-family:'Montserrat',sans-serif;font-size:18px;font-weight:400;
    padding:14px 4px;text-align:center;outline:none;transition:.25s;
  }
  .field input::placeholder{color:rgba(255,255,255,.4);}
  .field input:focus{border-color:var(--bleu-surfrider);}
  .nb{font-size:11px;color:rgba(255,255,255,.45);margin-top:20px;font-style:italic;font-weight:400;}

  /* --------- Certificat --------- */
  #s-cert{background:rgba(10,19,29,.55);backdrop-filter:blur(6px);}
  .certificat{
    background:var(--amande);color:var(--bleu-sombre);width:100%;max-width:430px;
    padding:38px 34px 30px;border-radius:3px;position:relative;text-align:center;
    box-shadow:0 40px 90px rgba(0,0,0,.6);border:1px solid rgba(26,48,71,.15);
    transform:scale(.86) translateY(20px);opacity:0;
  }
  .certificat.in{animation:certIn .8s cubic-bezier(.2,.8,.2,1) forwards;}
  @keyframes certIn{to{transform:scale(1) translateY(0);opacity:1;}}
  .certificat::before,.certificat::after{content:"";position:absolute;left:22px;right:22px;height:1px;background:rgba(26,48,71,.22);}
  .certificat::before{top:14px;}.certificat::after{bottom:62px;}
  .cert-kicker{font-size:10px;letter-spacing:.32em;text-transform:uppercase;color:var(--bleu-surfrider);font-weight:700;margin-bottom:14px;}
  .certificat h1{font-family:'Bebas Neue',sans-serif;font-size:46px;color:var(--bleu-sombre);line-height:.95;}
  .cert-name{font-family:'Bebas Neue',sans-serif;font-size:30px;color:var(--bleu-surfrider);margin:18px 0 4px;letter-spacing:.03em;}
  .cert-row{display:flex;justify-content:space-between;font-size:11px;margin-top:16px;color:var(--bleu-sombre);}
  .cert-row span{font-weight:700;letter-spacing:.04em;}
  .cert-row small{display:block;font-size:9px;letter-spacing:.12em;text-transform:uppercase;color:rgba(26,48,71,.55);font-weight:600;margin-bottom:2px;}
  .cert-sign{margin-top:24px;display:flex;align-items:center;justify-content:center;gap:10px;}
  .cert-sign .lg{height:30px;}
  .cert-foot{font-size:9.5px;letter-spacing:.05em;color:rgba(26,48,71,.6);margin-top:18px;font-style:italic;font-weight:400;}
  .cert-mail{font-size:10px;color:rgba(26,48,71,.55);margin-top:6px;font-weight:600;letter-spacing:.04em;}

  /* --------- Don --------- */
  #s-don{background:radial-gradient(circle at 50% 30%, #16344f 0%, var(--noir) 75%);}
  #s-don h1{font-size:clamp(34px,8vw,52px);}
  .don-rank{font-family:'Bebas Neue',sans-serif;font-size:clamp(56px,16vw,100px);color:var(--bleu-surfrider);line-height:.9;}
  .don-rank small{display:block;font-family:'Montserrat',sans-serif;font-size:13px;letter-spacing:.16em;text-transform:uppercase;color:rgba(255,255,255,.6);font-weight:600;margin-top:8px;}
  .montants{display:flex;gap:10px;justify-content:center;margin:28px 0 18px;flex-wrap:wrap;}
  .montant{border:1.5px solid rgba(255,255,255,.3);border-radius:2px;padding:14px 20px;cursor:pointer;transition:.2s;min-width:74px;}
  .montant .v{font-family:'Bebas Neue',sans-serif;font-size:26px;}
  .montant .net{font-size:9.5px;color:rgba(255,255,255,.55);margin-top:2px;font-weight:600;}
  .montant.sel{border-color:var(--bleu-surfrider);background:rgba(0,115,190,.18);}
  .montant.sel .v{color:var(--bleu-clair);}
  .defisc{font-size:12px;color:rgba(255,255,255,.6);max-width:380px;line-height:1.6;font-weight:400;margin-bottom:24px;}
  .defisc b{color:var(--bleu-clair);font-weight:700;}
  .skip{margin-top:22px;font-size:11px;letter-spacing:.14em;text-transform:uppercase;color:rgba(255,255,255,.4);background:none;border:none;cursor:pointer;font-family:'Montserrat',sans-serif;font-weight:600;}
  .skip:hover{color:rgba(255,255,255,.7);}

  /* logo bas de page / révélation */
  .logo-rev{display:flex;align-items:center;gap:11px;margin-bottom:26px;}
  .logo-rev .lg{height:42px;}
  .logo-rev .lg.txt{height:34px;}

  .fade-up{animation:fadeUp .9s ease both;}
  @keyframes fadeUp{from{opacity:0;transform:translateY(18px);}to{opacity:1;transform:translateY(0);}}
  .d1{animation-delay:.15s;}.d2{animation-delay:.35s;}.d3{animation-delay:.55s;}.d4{animation-delay:.75s;}

  @media(max-width:480px){
    .meta{gap:18px;}
    .montant{padding:12px 14px;min-width:64px;}
  }
</style>
</head>
<body>

<!-- 0 · INTRO -------------------------------------------------- -->
<section class="screen active" id="s-intro">
  <div class="wrap">
    <div class="lueur"></div>
    <h1>Adoptez<br>un PRESQUE RIEN.</h1>
    <p class="sub">Au début de cet écran, il n'y a rien.<br>Juste une lueur. Seule dans le noir.</p>
    <p class="sub" style="margin-top:22px;font-size:14px;">À vous seul, c'est un rien.</p>
    <div class="tap">Toucher pour continuer</div>
  </div>
</section>

<!-- 1 · PRINCIPE ----------------------------------------------- -->
<section class="screen" id="s-principe">
  <div class="wrap">
    <span class="h2 fade-up">Le principe</span>
    <h1 class="fade-up d1">Adoptez<br>un bout d'océan.</h1>
    <div class="dash center fade-up d1"></div>
    <p class="lead fade-up d2">Chaque personne adopte une parcelle.<br>Et plus nous sommes nombreux, <b>plus l'océan se rallume.</b></p>
    <p class="lead fade-up d3" style="font-size:14px;color:rgba(255,255,255,.6);">Tout seul, c'est un rien.<br>Ensemble, c'est une mer entière qui revit.</p>
    <button class="btn btn-plein fade-up d4" style="margin-top:14px;" onclick="go('s-carte')">Voir l'océan</button>
  </div>
</section>

<!-- 2 · CARTE -------------------------------------------------- -->
<section class="screen" id="s-carte">
  <canvas id="ocean"></canvas>
  <div class="carte-top">
    <span class="h2">La carte du RIEN</span>
    <h1>Choisissez<br>votre parcelle</h1>
    <div class="meta">
      <div>
        <div class="num" id="cnt">0</div>
        <div class="lbl">riens adoptés</div>
      </div>
      <div>
        <div class="num" id="pct">0%</div>
        <div class="lbl">repris au rien</div>
      </div>
    </div>
    <div class="barre"><i id="bar"></i></div>
  </div>
  <div class="hint" id="hint">Touchez une zone sombre de l'océan pour l'adopter</div>
  <div class="parcel-info" id="pinfo">
    <div class="pid" id="pid">RIEN-00000</div>
    <div class="coord" id="pcoord">0.0°N · 0.0°O</div>
  </div>
  <div class="carte-bottom">
    <button class="btn btn-plein" id="btnAdopt" disabled onclick="toEmail()">Adopter cette parcelle</button>
  </div>
</section>

<!-- 3 · EMAIL -------------------------------------------------- -->
<section class="screen" id="s-email">
  <div class="wrap">
    <span class="h2">Plus qu'une étape</span>
    <h1>Recevez votre<br>certificat d'adoption</h1>
    <div class="dash center"></div>
    <div class="field">
      <input type="email" id="email" placeholder="votre@email.fr" autocomplete="email" />
    </div>
    <button class="btn btn-plein" style="margin-top:18px;" id="btnCert" onclick="toCert()">Recevoir mon certificat</button>
    <p class="nb">Un seul champ. Pas de mot de passe. C'est le geste qui compte.</p>
  </div>
</section>

<!-- 4 · CERTIFICAT --------------------------------------------- -->
<section class="screen" id="s-cert">
  <div class="certificat" id="cert">
    <div class="cert-kicker">Certificat d'adoption</div>
    <h1>Vous avez<br>adopté un RIEN.</h1>
    <div class="cert-name" id="certName">VOTRE NOM</div>
    <div class="cert-row">
      <div><small>Parcelle</small><span id="certPid">RIEN-00000</span></div>
      <div style="text-align:right;"><small>Coordonnées</small><span id="certCoord">0.0°N · 0.0°O</span></div>
    </div>
    <div class="cert-row">
      <div><small>Date</small><span id="certDate">—</span></div>
      <div style="text-align:right;"><small>Statut</small><span style="color:var(--bleu-surfrider)">ACTIVE</span></div>
    </div>
    <div class="cert-sign" id="certSign"></div>
    <p class="cert-foot">« RIEN ne change tout seul. »</p>
    <p class="cert-mail">Une copie a été envoyée à votre adresse e-mail.</p>
    <button class="btn btn-plein" style="margin-top:22px;" onclick="go('s-don')">Continuer</button>
  </div>
</section>

<!-- 5 · DON ---------------------------------------------------- -->
<section class="screen" id="s-don">
  <div class="wrap">
    <div class="logo-rev fade-up" id="donLogo"></div>
    <span class="h2 fade-up d1">Vous n'êtes pas seul·e</span>
    <div class="don-rank fade-up d1" id="donRank">0<small>à avoir adopté un RIEN</small></div>
    <p class="defisc fade-up d2" style="margin-top:22px;">Derrière ce mouvement, une association protège les océans depuis 1990. <b>10 000 personnes financent déjà.</b> Bientôt 10 001 ?</p>
    <div class="montants fade-up d3" id="montants"></div>
    <p class="defisc fade-up d3">Grâce à la défiscalisation, <b id="netLabel">5 € ne vous coûtent que 1,70 €</b> après déduction.</p>
    <button class="btn btn-plein fade-up d4" onclick="merci()">Je soutiens le mouvement</button>
    <button class="skip fade-up d4" onclick="merci()">Plus tard — j'ai déjà adopté</button>
  </div>
</section>

<script>
/* ============================================================
   LOGO SURFRIDER (placeholder vectoriel — esprit charte)
   ⚠ À remplacer par le SVG/PNG officiel du kit de marque.
   ============================================================ */
function surfriderMark(color){
  return `<svg class="lg" viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg">
    <rect width="100" height="100" rx="6" fill="${color}"/>
    <g stroke="${color==='var(--blanc)'||color==='#FFFFFF'?'#0a131d':'#FFFFFF'}" stroke-width="3.4" fill="none" stroke-linecap="round">
      <path d="M16 70 Q40 70 58 52 Q74 36 84 22"/>
      <path d="M20 78 Q46 76 64 58 Q78 44 88 30"/>
      <path d="M26 84 Q52 82 70 66"/>
      <path d="M34 88 Q56 87 74 74"/>
    </g>
    <path d="M58 28 Q74 30 78 46 Q80 58 68 62 Q56 64 54 52 Q53 44 62 42" stroke="${color==='var(--blanc)'||color==='#FFFFFF'?'#0a131d':'#FFFFFF'}" stroke-width="3.4" fill="none" stroke-linecap="round"/>
  </svg>`;
}
function surfriderWordmark(color){
  return `<svg class="lg txt" viewBox="0 0 220 60" xmlns="http://www.w3.org/2000/svg">
    <text x="0" y="34" font-family="Montserrat,sans-serif" font-weight="700" font-size="30" letter-spacing="0.5" fill="${color}">SURFRIDER</text>
    <text x="1" y="52" font-family="Montserrat,sans-serif" font-weight="400" font-size="13" letter-spacing="2.4" fill="${color}">FOUNDATION <tspan font-weight="700">EUROPE</tspan></text>
  </svg>`;
}

/* ============================================================
   ÉTAT + PERSISTANCE (localStorage — par navigateur)
   ⚠ Pour un vrai compteur partagé entre appareils, brancher une
   petite API/back-end ; la logique de stockage est isolée ici.
   ============================================================ */
const BASE = 31483;               // riens déjà adoptés (amorce)
const OBJECTIF = 200000;          // pour la barre "% repris au RIEN"
const KEY='adopte_rien_v1';
function load(){
  try{const d=JSON.parse(localStorage.getItem(KEY));if(d&&Array.isArray(d.points))return d;}catch(e){}
  return {points:[], extra:0};
}
function save(s){ try{localStorage.setItem(KEY,JSON.stringify(s));}catch(e){} }
let state = load();
function totalCount(){ return BASE + state.extra + state.points.length; }

/* ============================================================
   NAVIGATION ENTRE ÉCRANS
   ============================================================ */
let current='s-intro';
function go(id){
  document.getElementById(current).classList.remove('active');
  document.getElementById(id).classList.add('active');
  current=id;
  if(id==='s-carte') startMap();
  if(id==='s-cert') buildCert();
  if(id==='s-don') buildDon();
}
document.getElementById('s-intro').addEventListener('click', ()=>{ if(current==='s-intro') go('s-principe'); });

/* ============================================================
   CARTE OCÉAN ANIMÉE (canvas) — planisphère
   continents en pointillés sombres · océans vivants en bleu Surfrider
   ============================================================ */
const cvs=document.getElementById('ocean');
const ctx=cvs.getContext('2d');
let W=0,H=0,DPR=1, map={x:0,y:0,w:0,h:0};
let landDots=[];           // pointillés des continents
let oceanBrightness=0;     // 0 = RIEN (noir) → 1 = océan rallumé
let particles=[];          // courants marins
let started=false, raf=null, t0=0;
let selection=null;        // {lon,lat,x,y,id,coord}

// continents simplifiés (lon,lat) — point-in-polygon
const CONTINENTS=[
 [[-165,68],[-140,71],[-100,73],[-82,68],[-60,60],[-56,50],[-66,45],[-70,42],[-80,30],[-97,16],[-105,20],[-114,28],[-124,40],[-130,52],[-150,60],[-165,68]], // Am. Nord
 [[-50,60],[-22,70],[-20,80],[-46,83],[-58,76],[-52,64]],                                                                                                  // Groenland
 [[-80,9],[-62,11],[-50,2],[-35,-7],[-40,-22],[-58,-35],[-66,-46],[-72,-52],[-74,-44],[-70,-30],[-78,-14],[-82,-3],[-80,9]],                                 // Am. Sud
 [[-10,36],[-9,44],[-2,48],[-6,57],[6,62],[14,66],[28,70],[42,67],[50,58],[42,50],[30,46],[16,44],[2,40],[-10,36]],                                          // Europe
 [[-16,30],[-4,36],[10,37],[24,33],[33,31],[44,12],[51,11],[48,0],[42,-12],[35,-22],[20,-35],[12,-30],[8,-16],[-8,5],[-16,18],[-16,30]],                      // Afrique
 [[28,40],[42,50],[52,55],[62,70],[100,77],[140,73],[168,67],[180,66],[180,58],[160,58],[145,52],[140,44],[122,38],[120,28],[108,18],[97,16],[90,22],[78,8],[72,20],[60,26],[46,40],[28,40]], // Asie
 [[114,-22],[122,-17],[132,-11],[143,-11],[150,-25],[150,-38],[138,-38],[128,-32],[115,-34],[114,-22]] // Australie
];

function pip(lon,lat,poly){
  let c=false;
  for(let i=0,j=poly.length-1;i<poly.length;j=i++){
    const xi=poly[i][0],yi=poly[i][1],xj=poly[j][0],yj=poly[j][1];
    if(((yi>lat)!==(yj>lat)) && (lon < (xj-xi)*(lat-yi)/(yj-yi)+xi)) c=!c;
  }
  return c;
}
function isLand(lon,lat){ for(const p of CONTINENTS) if(pip(lon,lat,p)) return true; return false; }
function lonlatToXY(lon,lat){ return { x: map.x + (lon+180)/360*map.w, y: map.y + (90-lat)/180*map.h }; }
function xyToLonLat(x,y){ return { lon:(x-map.x)/map.w*360-180, lat:90-(y-map.y)/map.h*180 }; }

function resize(){
  DPR=Math.min(window.devicePixelRatio||1,2);
  W=window.innerWidth; H=window.innerHeight;
  cvs.width=W*DPR; cvs.height=H*DPR; ctx.setTransform(DPR,0,0,DPR,0,0);
  // carte 2:1 centrée
  let mw=Math.min(W*1.02, H*2.0); let mh=mw/2;
  if(mh>H*0.96){ mh=H*0.96; mw=mh*2; }
  map={ x:(W-mw)/2, y:(H-mh)/2, w:mw, h:mh };
  buildLandDots();
}
function buildLandDots(){
  landDots=[];
  const step=Math.max(7, map.w/120);
  for(let x=map.x; x<map.x+map.w; x+=step){
    for(let y=map.y; y<map.y+map.h; y+=step){
      const {lon,lat}=xyToLonLat(x+(Math.random()-.5)*step*.6, y+(Math.random()-.5)*step*.6);
      if(isLand(lon,lat)) landDots.push({x:x+(Math.random()-.5)*step*.6, y:y+(Math.random()-.5)*step*.6});
    }
  }
  particles=[];
  for(let i=0;i<70;i++){
    let px,py,tries=0;
    do{ px=map.x+Math.random()*map.w; py=map.y+Math.random()*map.h; tries++; }
    while(isLand(...Object.values(xyToLonLat(px,py))) && tries<8);
    particles.push({x:px,y:py,sp:.15+Math.random()*.35,len:8+Math.random()*22,o:.1+Math.random()*.25});
  }
}
window.addEventListener('resize', ()=>{ if(started){ resize(); } });

function startMap(){
  resize();
  oceanBrightness=0;
  refreshCounters(true);
  if(!started){ started=true; t0=performance.now(); raf=requestAnimationFrame(loop); }
}

function loop(now){
  const tt=(now-t0)/1000;
  // rallumage progressif de l'océan
  oceanBrightness += (1-oceanBrightness)*0.012;
  draw(tt);
  raf=requestAnimationFrame(loop);
}

function draw(tt){
  // fond "RIEN"
  const bg=ctx.createLinearGradient(0,0,0,H);
  bg.addColorStop(0,'#0a131d'); bg.addColorStop(1,'#060d14');
  ctx.fillStyle=bg; ctx.fillRect(0,0,W,H);

  // --- OCÉAN VIVANT (limité à la zone carte) ---
  ctx.save();
  ctx.beginPath(); ctx.rect(map.x,map.y,map.w,map.h); ctx.clip();

  // teinte de base de l'eau
  const b=oceanBrightness;
  const og=ctx.createLinearGradient(map.x,map.y,map.x+map.w,map.y+map.h);
  og.addColorStop(0, `rgba(11,40,66,${0.25+0.45*b})`);
  og.addColorStop(.5,`rgba(0,90,150,${0.20+0.40*b})`);
  og.addColorStop(1, `rgba(8,34,56,${0.25+0.45*b})`);
  ctx.fillStyle=og; ctx.fillRect(map.x,map.y,map.w,map.h);

  // caustiques (reflets de lumière qui dérivent)
  ctx.globalCompositeOperation='screen';
  for(let i=0;i<6;i++){
    const cx=map.x+map.w*(0.5+0.42*Math.sin(tt*0.18+i*1.7));
    const cy=map.y+map.h*(0.5+0.42*Math.cos(tt*0.13+i*2.1));
    const r=map.w*(0.14+0.05*Math.sin(tt*0.3+i));
    const g=ctx.createRadialGradient(cx,cy,0,cx,cy,r);
    g.addColorStop(0,`rgba(0,115,190,${0.16*b})`);
    g.addColorStop(1,'rgba(0,115,190,0)');
    ctx.fillStyle=g; ctx.beginPath(); ctx.arc(cx,cy,r,0,7); ctx.fill();
  }

  // balayage du soleil (diagonale, ~9s)
  const sweep=((tt/9)%1);
  const sx=map.x-map.w*0.4 + sweep*map.w*1.8;
  const sg=ctx.createLinearGradient(sx-120,map.y,sx+120,map.y+map.h);
  sg.addColorStop(0,'rgba(203,223,245,0)');
  sg.addColorStop(.5,`rgba(203,223,245,${0.10*b})`);
  sg.addColorStop(1,'rgba(203,223,245,0)');
  ctx.fillStyle=sg; ctx.fillRect(map.x,map.y,map.w,map.h);

  // courants (particules)
  ctx.lineCap='round';
  particles.forEach(p=>{
    p.x+=p.sp; if(p.x>map.x+map.w+30) p.x=map.x-30;
    ctx.strokeStyle=`rgba(203,223,245,${p.o*b})`; ctx.lineWidth=1.1;
    ctx.beginPath(); ctx.moveTo(p.x,p.y); ctx.lineTo(p.x-p.len,p.y+1); ctx.stroke();
  });
  ctx.globalCompositeOperation='source-over';
  ctx.restore();

  // --- CONTINENTS (pointillés sombres, par-dessus l'eau) ---
  ctx.save();
  ctx.fillStyle='rgba(8,16,25,0.92)';
  CONTINENTS.forEach(poly=>{
    ctx.beginPath();
    poly.forEach((pt,i)=>{ const c=lonlatToXY(pt[0],pt[1]); i?ctx.lineTo(c.x,c.y):ctx.moveTo(c.x,c.y); });
    ctx.closePath(); ctx.fill();
  });
  landDots.forEach(d=>{ ctx.fillStyle='rgba(120,142,168,0.35)'; ctx.beginPath(); ctx.arc(d.x,d.y,1.3,0,7); ctx.fill(); });
  ctx.restore();

  // --- ADOPTIONS EXISTANTES (lueurs bleu Surfrider) ---
  state.points.forEach((pt,i)=>{
    const c=lonlatToXY(pt.lon,pt.lat);
    const pulse=0.6+0.4*Math.sin(tt*1.6+i);
    glow(c.x,c.y,3.2,pulse,false);
  });

  // --- SÉLECTION EN COURS ---
  if(selection){
    const c=lonlatToXY(selection.lon,selection.lat);
    const rp=8+4*Math.sin(tt*3);
    ctx.strokeStyle='rgba(203,223,245,.9)'; ctx.lineWidth=1.6;
    ctx.beginPath(); ctx.arc(c.x,c.y,rp+6,0,7); ctx.stroke();
    glow(c.x,c.y,4,1,true);
  }
}
function glow(x,y,r,a,bright){
  const g=ctx.createRadialGradient(x,y,0,x,y,r*5);
  g.addColorStop(0,`rgba(${bright?'203,223,245':'0,134,218'},${a})`);
  g.addColorStop(.4,`rgba(0,115,190,${a*0.5})`);
  g.addColorStop(1,'rgba(0,115,190,0)');
  ctx.fillStyle=g; ctx.beginPath(); ctx.arc(x,y,r*5,0,7); ctx.fill();
  ctx.fillStyle=`rgba(${bright?'255,255,255':'203,223,245'},${a})`;
  ctx.beginPath(); ctx.arc(x,y,r,0,7); ctx.fill();
}

// clic / tap sur la carte
cvs.addEventListener('click', e=>{
  const rect=cvs.getBoundingClientRect();
  const x=e.clientX-rect.left, y=e.clientY-rect.top;
  if(x<map.x||x>map.x+map.w||y<map.y||y>map.y+map.h) return;
  const {lon,lat}=xyToLonLat(x,y);
  if(isLand(lon,lat)) return; // on n'adopte que l'océan
  const id='RIEN-'+String(Math.floor(10000+Math.random()*89999));
  const ns=lat>=0?'N':'S', ew=lon>=0?'E':'O';
  const coord=`${Math.abs(lat).toFixed(1)}°${ns} · ${Math.abs(lon).toFixed(1)}°${ew}`;
  selection={lon,lat,id,coord};
  document.getElementById('pid').textContent=id;
  document.getElementById('pcoord').textContent=coord;
  document.getElementById('pinfo').classList.add('show');
  document.getElementById('hint').style.opacity=0;
  document.getElementById('btnAdopt').disabled=false;
});

/* ============================================================
   COMPTEURS
   ============================================================ */
function refreshCounters(animate){
  const total=totalCount();
  const pct=Math.min(100, total/OBJECTIF*100);
  const el=document.getElementById('cnt');
  if(animate){
    let v=0; const target=total; const step=Math.ceil(target/60);
    const t=setInterval(()=>{ v+=step; if(v>=target){v=target;clearInterval(t);} el.textContent=v.toLocaleString('fr-FR'); },18);
  } else el.textContent=total.toLocaleString('fr-FR');
  document.getElementById('pct').textContent=pct.toFixed(pct<1?1:0)+'%';
  document.getElementById('bar').style.width=Math.max(2,pct)+'%';
}

/* ============================================================
   PARCOURS : carte → email → certificat → don
   ============================================================ */
function toEmail(){ if(!selection) return; go('s-email'); }

function toCert(){
  const mail=document.getElementById('email').value.trim();
  if(!/.+@.+\..+/.test(mail)){ document.getElementById('email').focus(); return; }
  // enregistrement de l'adoption
  state.points.push({lon:selection.lon,lat:selection.lat,id:selection.id});
  save(state);
  window._lastMail=mail;
  go('s-cert');
}

function buildCert(){
  const mail=window._lastMail||'';
  const name=(mail.split('@')[0]||'citoyen').replace(/[._-]+/g,' ');
  document.getElementById('certName').textContent=name.toUpperCase();
  document.getElementById('certPid').textContent=selection.id;
  document.getElementById('certCoord').textContent=selection.coord;
  document.getElementById('certDate').textContent=new Date().toLocaleDateString('fr-FR');
  document.getElementById('certSign').innerHTML=surfriderMark('var(--bleu-surfrider)')+surfriderWordmark('#1A3047');
  document.querySelectorAll('#certSign .lg')[0].style.height='30px';
  const c=document.getElementById('cert'); c.classList.remove('in'); void c.offsetWidth; c.classList.add('in');
}

let montant=5;
const PALIERS=[5,10,20,50];
function buildDon(){
  refreshCounters(false);
  document.getElementById('donRank').innerHTML=totalCount().toLocaleString('fr-FR')+"<small>e à avoir adopté un RIEN</small>";
  document.getElementById('donLogo').innerHTML=surfriderMark('var(--bleu-surfrider)')+surfriderWordmark('#FFFFFF');
  const box=document.getElementById('montants'); box.innerHTML='';
  PALIERS.forEach(v=>{
    const net=(v*0.34).toFixed(2).replace('.',',');
    const d=document.createElement('div');
    d.className='montant'+(v===montant?' sel':'');
    d.innerHTML=`<div class="v">${v}€</div><div class="net">soit ${net}€</div>`;
    d.onclick=()=>{ montant=v; buildDon(); };
    box.appendChild(d);
  });
  const net=(montant*0.34).toFixed(2).replace('.',',');
  document.getElementById('netLabel').textContent=`${montant}\u00A0€ ne vous coûtent que ${net}\u00A0€`;
}

function merci(){
  document.getElementById('s-don').innerHTML=
   `<div class="wrap">
      <div class="logo-rev fade-up" style="justify-content:center;">${surfriderMark('var(--bleu-surfrider)')}${surfriderWordmark('#FFFFFF')}</div>
      <h1 class="fade-up d1" style="font-size:clamp(40px,10vw,70px);">Bienvenue<br>dans le mouvement.</h1>
      <div class="dash center fade-up d1"></div>
      <p class="lead fade-up d2">Votre parcelle est désormais <b>active</b>.<br>Et l'océan, lui, n'est plus tout à fait un rien.</p>
      <p class="lead fade-up d3" style="font-size:14px;color:rgba(255,255,255,.55);">« RIEN ne change tout seul. »</p>
    </div>`;
}

